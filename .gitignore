# =============================================================================
# AstroEX .gitignore
# =============================================================================

# --- Personal / PII (NEVER commit) ------------------------------------------
user_data/
materials/
materials-deployed/

# --- Runtime data & pipeline output -----------------------------------------
data/
logs/
runtime_logs/

# --- Build output ------------------------------------------------------------
dist/
node_modules/

# --- Environment & secrets ---------------------------------------------------
.env
.env.*
!.env.example

# --- Developer scratch files -------------------------------------------------
debug_scrape_output.json
debug_url.js
verify_maxTokens_limits.js
implementation_plan.md
*.old
*.orig

# --- Ad-hoc root-level test & debug scripts ----------------------------------
# (keep test/ directory — that is the formal test suite)
test_*.ps1
test_*.js
test-*.js
testie.bash
testie_log.bash
testicle.bash
testicle.ps1

# --- OS & editor noise -------------------------------------------------------
.DS_Store
Thumbs.db
.vscode/settings.json
